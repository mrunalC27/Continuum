{
  "manifest_version": 3,
  "name": "Continuum",
  "version": "0.1.0",
  "description": "Extract and preserve AI project context across sessions",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "commands"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "utils/scraper.js",
        "content/chatgpt.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://claude.ai/*"
      ],
      "js": [
        "utils/scraper.js",
        "content/claude.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "ContextBridge"
  },
  "commands": {
    "trigger-extract": {
      "suggested_key": {
        "default": "Ctrl+Shift+E",
        "mac": "Command+Shift+E"
      },
      "description": "Extract current conversation"
    }
  }
}